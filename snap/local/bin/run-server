#!/bin/sh
# run-server — se-llama wrapper for llama-server
# Seeds presets.ini on first run, then execs llama-server with preset flags prepended.

PRESETS_FILE="$SNAP_USER_COMMON/config/presets.ini"
MODELS_USER_DIR="$SNAP_USER_COMMON/models/user"

mkdir -p "$SNAP_USER_COMMON/config" "$MODELS_USER_DIR" "$SNAP_USER_COMMON/run" "$SNAP_USER_DATA/logs"

# Seed config on first run.
if [ ! -f "$PRESETS_FILE" ]; then
    python3 "$SNAP/libexec/generate_presets.py" >&2
fi

# Exec llama-server with presets and models dir prepended; user flags follow
exec "$SNAP/usr/bin/llama-server" \
    --models-preset "$PRESETS_FILE" \
    --models-dir    "$MODELS_USER_DIR/" \
    "$@"
